{
  "name": "hostr",
  "description": "Hostr - simple sharing",
  "repository": "https://github.com/kudos/hostr-web",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "iojs": "^3.2.0",
    "npm": "^3.3.0"
  },
  "scripts": {
    "build": "npm run build-js && npm run build-sass",
    "build-js": "babel -D -m system -d web/public/app/build web/public/app/src",
    "build-sass": "node-sass --include-path web/public/app/jspm_packages/github/twbs/bootstrap@4.0.0-alpha/scss/ web/public/app/src/scss/style.scss web/public/app/build/css/style.css",
    "cover": "istanbul cover _mocha -- -r babel/register test/**/*.spec.js",
    "init": "node -r babel/register -e \"require('./lib/storage')();\"",
    "jspm": "jspm install",
    "start": "npm run build && node -r babel/register app.js",
    "test": "mongo hostr test/fixtures/mongo-*.js && mocha -r babel/register test/**/*.spec.js",
    "watch": "parallelshell \"npm run watch-js\" \"npm run watch-sass\" \"npm run watch-server\"",
    "watch-js": "babel -Dw -m system -d web/public/app/build web/public/app/src",
    "watch-server": "nodemon -x 'babel-node' app.js",
    "watch-sass": "node-sass  --include-path web/public/app/jspm_packages/github/twbs/bootstrap@4.0.0-alpha/scss/ -w web/public/app/src/scss/style.scss web/public/app/build/css/style.css"
  },
  "dependencies": {
    "aws-sdk": "~2.1.46",
    "babel": "~5.8.21",
    "basic-auth": "~1.0.3",
    "co": "~4.6.0",
    "co-busboy": "~1.3.0",
    "co-redis": "~1.2.1",
    "co-views": "~2.1.0",
    "debug": "~2.2.0",
    "ejs": "~2.3.2",
    "form-data": "^1.0.0-rc3",
    "gm": "~1.18.1",
    "http-errors": "~1.3.1",
    "jspm": "~0.16.0",
    "kcors": "~1.0.1",
    "koa": "~1.0.0",
    "koa-bodyparser": "~2.0.1",
    "koa-compress": "~1.0.8",
    "koa-csrf": "~2.3.0",
    "koa-error": "^1.1.3",
    "koa-favicon": "~1.2.0",
    "koa-generic-session": "~1.9.0",
    "koa-helmet": "^0.2.0",
    "koa-logger": "~1.3.0",
    "koa-redis": "~1.0.1",
    "koa-router": "^5.1.2",
    "koa-static": "^1.4.9",
    "koa-statsd": "~0.0.2",
    "koa-views": "~3.1.0",
    "koa-websocket": "~1.1.0",
    "mandrill-api": "~1.0.45",
    "mime-types": "~2.1.5",
    "moment": "~2.10.6",
    "mongodb-promisified": "~1.0.3",
    "node-fetch": "^1.3.2",
    "node-sass": "~3.3.0",
    "node-uuid": "~1.4.3",
    "passwords": "~1.3.0",
    "raven": "~0.8.1",
    "react": "^0.13.3",
    "react-google-analytics": "^0.2.0",
    "react-router": "^0.13.3",
    "redis": "~1.0.0",
    "s3-upload-stream": "~1.0.7",
    "statsy": "~0.2.0",
    "stripe": "~3.7.1"
  },
  "devDependencies": {
    "babel-eslint": "^4.0.10",
    "eslint": "~1.3.0",
    "eslint-config-airbnb": "0.0.8",
    "eslint-plugin-react": "^3.3.1",
    "istanbul": "~0.3.18",
    "mocha": "~2.2.5",
    "nodemon": "~1.4.1",
    "parallelshell": "~2.0.0",
    "supertest": "~1.1.0",
    "tmp": "~0.0.27"
  },
  "jspm": {
    "directories": {
      "baseURL": "web/public",
      "packages": "web/public/app/jspm_packages"
    },
    "configFile": "web/public/app/config.js",
    "dependencies": {
      "react": "npm:react@^0.13.3",
      "react-google-analytics": "npm:react-google-analytics@^0.2.0",
      "react-router": "npm:react-router@^0.13.3",
      "twbs/bootstrap": "github:twbs/bootstrap@^4.0.0-alpha"
    },
    "devDependencies": {
      "babel": "npm:babel-core@^5.8.22",
      "babel-runtime": "npm:babel-runtime@^5.8.20",
      "core-js": "npm:core-js@^1.1.0"
    },
    "overrides": {
      "github:twbs/bootstrap@4.0.0-alpha": {
        "main": "js/bootstrap",
        "files": [
          "js",
          "scss"
        ],
        "directories": {}
      }
    }
  }
}
