{
  "name": "hostr",
  "description": "Hostr - simple sharing",
  "repository": "https://github.com/kudos/hostr-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=26.0.0"
  },
  "scripts": {
    "build": "pnpm run build-js && pnpm run build-sass",
    "build-js": "webpack --mode=production --progress --config webpack.config.cjs",
    "build-sass": "sass --load-path=./node_modules/ web/public/styles/",
    "heroku-postbuild": "pnpm run build",
    "init": "node -e \"import('./lib/storage.js').then(m => m.default())\"",
    "initdb": "node test/initdb.js",
    "lint": "eslint .",
    "start": "node app.js",
    "test": "pnpm run test-seed && mocha --exit --timeout=15000 test/**/*.spec.js",
    "test-seed": "node test/fixtures/user.js",
    "watch": "concurrently -k -n watch-js,watch-sass \"pnpm run watch-js\" \"pnpm run watch-sass\"",
    "watch-js": "webpack -w --mode=development --progress --config webpack.config.cjs",
    "watch-server": "nodemon -i web/public",
    "watch-sass": "sass --load-path=./node_modules/ -w web/public/styles/"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "busboy": "^1.6.0",
    "debug": "^4.4.3",
    "ejs": "^6.0.0",
    "form-data": "^4.0.5",
    "hono": "^4.12.19",
    "image-size": "^2.0.2",
    "jimp": "^1.6.1",
    "mime-types": "^3.0.2",
    "nodemailer": "^8.0.7",
    "passwords": "^1.3.1",
    "pg": "^8.20.0",
    "redis": "^6.0.0",
    "sequelize": "^6.37.8",
    "uuid": "^14.0.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "bootstrap-sass": "^3.4.3",
    "concurrently": "^10.0.0",
    "dropzone": "6.0.0-beta.2",
    "esbuild-loader": "^4.4.3",
    "eslint": "^10.4.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import-x": "^4.16.2",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "sass": "^1.99.0",
    "supertest": "^7.2.2",
    "tmp": "^0.2.5",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}
