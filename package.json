{
  "name": "hostr",
  "description": "Hostr - simple sharing",
  "repository": "https://github.com/kudos/hostr-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "yarn run build-js && yarn run build-sass",
    "build-js": "webpack --mode=production --progress --config webpack.config.cjs",
    "build-sass": "sass --load-path=./node_modules/ web/public/styles/",
    "heroku-postbuild": "yarn run build",
    "init": "node -e \"import('./lib/storage.js').then(m => m.default())\"",
    "initdb": "node test/initdb.js",
    "lint": "eslint .",
    "start": "node app.js",
    "test": "yarn run test-seed && mocha test/**/*.spec.js",
    "test-seed": "node test/fixtures/user.js",
    "watch": "concurrently -k -n watch-js,watch-sass \"yarn run watch-js\" \"yarn run watch-sass\"",
    "watch-js": "webpack -w --mode=development --progress --config webpack.config.cjs",
    "watch-server": "nodemon -i web/public",
    "watch-sass": "sass --load-path=./node_modules/ -w web/public/styles/"
  },
  "resolutions": {
    "yaml": "^2.8.3",
    "ansi-regex": "^6.0.0",
    "minimatch": "^10.0.0",
    "serialize-javascript": "^7.0.5",
    "debug": "^4.4.3",
    "qs": "^6.14.2"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "bootstrap-sass": "^3.4.0",
    "busboy": "^1.0.0",
    "debug": "^4.4.0",
    "dropzone": "~6.0.0-beta.2",
    "ejs": "^5.0.2",
    "form-data": "^4.0.0",
    "hono": "^4.0.0",
    "image-size": "^2.0.0",
    "jimp": "^1.0.0",
    "mime-types": "^3.0.0",
    "nodemailer": "^8.0.5",
    "nodemon": "^3.1.10",
    "passwords": "^1.3.1",
    "pg": "^8.13.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "redis": "^5.0.0",
    "sass": "^1.89.2",
    "sequelize": "^6.0.0",
    "uuid": "^14.0.0",
    "ws": "^8.0.0",
    "webpack": "^5.105.0",
    "webpack-cli": "^7.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-react": "^7.0.0",
    "@eslint/eslintrc": "^3.0.0",
    "babel-loader": "^10.1.1",
    "concurrently": "^9.0.0",
    "eslint": "^10.0.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import-x": "^4.0.0",
    "mocha": "^11.0.0",
    "supertest": "^7.0.0",
    "tmp": "^0.2.5"
  }
}
