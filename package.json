{
  "name": "hostr",
  "description": "Hostr - simple sharing",
  "repository": "https://github.com/kudos/hostr",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": "^5.3.0",
    "npm": "^3.3.0"
  },
  "scripts": {
    "build": "npm run build-js && npm run build-sass",
    "build-js": "npm run build-js-deps && npm run build-js-app",
    "build-js-deps": "jspm bundle src/app.js - [src/**/*] - [views/**/*] + babel/external-helpers  web/public/app/build/deps-bundle.js",
    "build-js-app": "jspm bundle src/app.js - build/deps-bundle.js web/public/app/build/app-bundle.js --minify",
    "build-sass": "node-sass --include-path web/public/app/jspm_packages/github/twbs/bootstrap@4.0.0-alpha/scss/ --output-style compressed --source-map web/public/app/build/css/style.css.map --output web/public/app/build/css/ web/public/app/src/scss/style.scss",
    "cover": "istanbul cover _mocha -- -r babel-register test/**/*.spec.js",
    "init": "node -r babel-register -e \"require('./lib/storage')();\"",
    "jspm": "jspm install",
    "start": "npm run init && npm run build && node -r babel-register app.js",
    "test": "mongo hostr test/fixtures/mongo-*.js && mocha -r babel-register test/**/*.spec.js",
    "watch": "parallelshell -w \"npm run watch-js\" \"npm run watch-sass\" \"npm run watch-server\"",
    "watch-js": "babel --babelrc web/public/app/.babelrc-browser --source-maps --copy-files --watch --modules system --out-dir web/public/app/build web/public/app/src",
    "watch-server": "nodemon -r babel-register -i web/public/app/build app.js",
    "watch-sass": "npm run build-sass && node-sass --include-path web/public/app/jspm_packages/github/twbs/bootstrap@4.0.0-alpha/scss/ --source-map web/public/app/build/css/style.css.map --output web/public/app/build/css/ --watch web/public/app/src/scss/style.scss"
  },
  "dependencies": {
    "attr-accept": "~1.0.1",
    "aws-sdk": "~2.2.10",
    "babel": "~6.3.13",
    "babel-cli": "^6.3.17",
    "babel-core": "^6.3.21",
    "babel-plugin-syntax-jsx": "^6.3.13",
    "babel-plugin-syntax-object-rest-spread": "^6.3.13",
    "babel-plugin-transform-es2015-constants": "^6.1.4",
    "babel-plugin-transform-object-rest-spread": "^6.3.13",
    "babel-plugin-transform-react-jsx": "^6.3.13",
    "babel-polyfill": "^6.3.14",
    "babel-preset-es2015": "^6.3.13",
    "babel-register": "^6.3.13",
    "basic-auth": "~1.0.3",
    "canvas": "~1.3.5",
    "co": "~4.6.0",
    "co-busboy": "~1.3.0",
    "co-redis": "~2.0.0",
    "co-views": "~2.1.0",
    "cookie-dough": "0.0.6",
    "cookie-parser": "~1.4.0",
    "debug": "~2.2.0",
    "ejs": "~2.3.2",
    "form-data": "~1.0.0-rc3",
    "gm": "~1.21.1",
    "history": "^1.12.3",
    "http-errors": "~1.3.1",
    "jspm": "~0.16.12",
    "kcors": "~1.0.1",
    "koa": "~1.1.0",
    "koa-bodyparser": "~2.0.1",
    "koa-compress": "~1.0.8",
    "koa-csrf": "~2.4.0",
    "koa-error": "~1.1.3",
    "koa-favicon": "~1.2.0",
    "koa-generic-session": "~1.10.1",
    "koa-helmet": "~0.4.0",
    "koa-jwt": "~1.1.1",
    "koa-logger": "~1.3.0",
    "koa-redis": "~1.0.1",
    "koa-router": "~5.3.0",
    "koa-static": "~1.5.1",
    "koa-statsd": "~0.0.2",
    "koa-views": "~3.1.0",
    "koa-websocket": "~1.1.0",
    "mandrill-api": "~1.0.45",
    "mime-types": "~2.1.5",
    "mkdirp": "~0.5.1",
    "moment": "~2.10.6",
    "mongodb-promisified": "~1.0.3",
    "node-fetch": "~1.3.3",
    "node-sass": "~3.4.2",
    "node-uuid": "~1.4.3",
    "passwords": "~1.3.0",
    "raven": "~0.9.0",
    "react": "~0.14.0",
    "react-dom": "~0.14.0",
    "react-dropzone": "~3.3.0",
    "react-google-analytics": "~0.2.0",
    "react-redux": "~4.0.0",
    "react-router": "~1.0.0",
    "redis": "~2.4.2",
    "redux": "~3.0.0",
    "rethinkdbdash": "~2.2.12",
    "s3-upload-stream": "~1.0.7",
    "smartcrop": "0.0.1",
    "statsy": "~0.2.0",
    "stripe": "~4.1.0",
    "superagent": "~1.6.1",
    "superagent-promise": "~1.0.3"
  },
  "devDependencies": {
    "babel-eslint": "~5.0.0-beta6",
    "eslint": "~1.10.3",
    "eslint-config-airbnb": "2.1.1",
    "eslint-plugin-react": "~3.12.0",
    "istanbul": "~0.4.0",
    "mocha": "~2.3.0",
    "nodemon": "~1.8.1",
    "parallelshell": "~2.0.0",
    "redux-devtools": "~3.0.0",
    "supertest": "~1.1.0",
    "tmp": "~0.0.28"
  },
  "babel": {
    "whitelist": [
      "react",
      "strict",
      "es6.modules",
      "es6.parameters",
      "es6.destructuring",
      "es6.spread",
      "es7.objectRestSpread"
    ]
  },
  "jspm": {
    "directories": {
      "baseURL": "web/public/app"
    },
    "dependencies": {
      "attr-accept": "npm:attr-accept@~1.0.1",
      "babel-polyfill": "npm:babel-polyfill@^6.3.14",
      "bootstrap": "github:twbs/bootstrap@4.0.0-alpha",
      "co": "npm:co@~4.6.0",
      "cookie-dough": "npm:cookie-dough@~0.0.6",
      "history": "npm:history@~1.9.1",
      "react": "npm:react@~0.14.3",
      "react-dom": "npm:react-dom@~0.14.0",
      "react-dropzone": "npm:react-dropzone@~3.3.0",
      "react-google-analytics": "npm:react-google-analytics@~0.2.0",
      "react-redux": "npm:react-redux@~4.0.0",
      "react-router": "npm:react-router@~1.0.0",
      "redux": "npm:redux@~3.0.0",
      "redux-devtools": "npm:redux-devtools@~3.0.0",
      "regenerator": "npm:regenerator@~0.8.38",
      "superagent": "npm:superagent@~1.4.0",
      "superagent-promise": "npm:superagent-promise@~1.0.3"
    },
    "devDependencies": {
      "babel": "npm:babel-core@~5.8.25",
      "babel-runtime": "npm:babel-runtime@~5.8.24",
      "core-js": "npm:core-js@~1.1.4"
    },
    "overrides": {
      "github:twbs/bootstrap@4.0.0-alpha": {
        "main": "js/bootstrap",
        "files": [
          "js",
          "scss"
        ],
        "directories": {},
        "shim": {},
        "dependencies": {},
        "map": {
          "jquery": "@empty"
        }
      }
    }
  }
}
