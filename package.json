{
  "name": "hostr",
  "description": "Hostr - simple sharing",
  "repository": "https://github.com/kudos/hostr-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "yarn run build-js && yarn run build-sass",
    "build-js": "webpack --mode=production --progress --config webpack.config.cjs",
    "build-sass": "sass --load-path=./node_modules/ web/public/styles/",
    "heroku-postbuild": "yarn run build",
    "init": "node -e \"import('./lib/storage.js').then(m => m.default())\"",
    "initdb": "node test/initdb.js",
    "lint": "eslint .",
    "start": "node app.js",
    "test": "yarn run test-seed && mocha test/**/*.spec.js",
    "test-seed": "node test/fixtures/user.js",
    "watch": "concurrently -k -n watch-js,watch-sass \"yarn run watch-js\" \"yarn run watch-sass\"",
    "watch-js": "webpack -w --mode=development --progress --config webpack.config.cjs",
    "watch-server": "nodemon -i web/public",
    "watch-sass": "sass --load-path=./node_modules/ -w web/public/styles/"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/lib-storage": "^3.0.0",
    "@koa/bodyparser": "^6.0.0",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.3.0",
    "@ladjs/koa-views": "^9.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@sendgrid/mail": "^8.0.0",
    "angular": "^1.7.9",
    "angular-reconnecting-websocket": "https://github.com/adieu/angular-reconnecting-websocket#v0.1.1",
    "angular-resource": "^1.7.9",
    "angular-route": "^1.7.9",
    "angular-strap": "^2.3.8",
    "basic-auth": "~2.0.1",
    "bootstrap-sass": "^3.4.0",
    "busboy": "^1.0.0",
    "co-views": "~2.1.0",
    "copy-webpack-plugin": "^13.0.0",
    "debug": "^4.4.0",
    "dropzone": "~5.7.6",
    "ejs": "^4.0.0",
    "form-data": "^4.0.0",
    "helmet": "^8.0.0",
    "http-errors": "^2.0.0",
    "image-size": "^2.0.0",
    "jimp": "^1.0.0",
    "koa": "^3.1.1",
    "koa-compress": "^5.2.0",
    "koa-csrf": "^5.0.1",
    "koa-error": "^3.2.0",
    "koa-favicon": "~2.1.0",
    "koa-helmet": "^9.0.0",
    "koa-logger": "^4.0.0",
    "koa-session": "^7.0.0",
    "koa-static": "^5.0.0",
    "koa-websocket": "^7.0.0",
    "mime-types": "^3.0.0",
    "moment": "^2.30.0",
    "nodemon": "^3.1.10",
    "passwords": "^1.3.1",
    "pg": "^8.13.0",
    "redis": "^5.0.0",
    "sass": "^1.89.2",
    "sequelize": "^6.0.0",
    "smooth-scroll": "https://github.com/cferdinandi/smooth-scroll#5.3.7",
    "statsy": "~0.2.0",
    "stripe": "^20.0.0",
    "uuid": "^13.0.0",
    "webpack": "^5.105.0",
    "webpack-cli": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^10.0.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-import-x": "^4.0.0",
    "mocha": "^11.0.0",
    "supertest": "^7.0.0",
    "tmp": "^0.2.5"
  }
}
