NODE_ENV=test

# App
WEB_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000
COOKIE_KEY=ci-test-cookie-key-not-for-production
UPLOAD_STORAGE_PATH=/tmp/uploads

# Database — hostname matches the service name in ci.yml
DATABASE_URL=postgres://hostr:hostr@database/hostr

# Redis — hostname matches the service name in ci.yml
REDIS_URL=redis://redis:6379
